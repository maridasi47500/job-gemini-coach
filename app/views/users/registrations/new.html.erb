<h2>Sign up</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "users/shared/error_messages", resource: resource %>

  <div class="field">
    <p><%= f.label :email %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>
  <div class="field">
    <p><%= f.label :nomcomplet %></p>
    <p><%= f.text_field :nomcomplet %></p>
  </div>
  <div class="field">
    <p><%= f.label :salaire %></p>
    <p><%= f.text_field :salaire %></p>
  </div>
  <div class="field">
    <p><%= f.label :experience %></p>
    <p><%= f.text_field :experience %></p>
  </div>
  <div class="field">
    <p><%= f.label :job_id %></p>
    <p><%= f.collection_select :job_id, Job.all, :id, :name %></p>
  </div>
  <div class="field">
    <p><%= f.label :country_id %></p>
    <p><%= f.collection_select :country_id, Country.all, :id, :name %></p>
  </div>
  <div class="field">
    <p><%= f.label :city_id %></p>
    <p><%= f.collection_select :city_id, City.all, :id, :name %></p>
  </div>
  <div class="field">
    <p><%= f.label :secteur_id %></p>
    <p><%= f.collection_select :secteur_id, Secteur.all, :id, :name %></p>
  </div>

  <div class="field">
    <p><%= f.label :password %></p>
    <% if @minimum_password_length %>
      <p><em>(<%= @minimum_password_length %> characters minimum)</em></p>
    <% end %>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit "Sign up" %>
  </div>
<% end %>

<%= render "users/shared/links" %>
